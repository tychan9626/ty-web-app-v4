            <mat-label>Assigned User</mat-label>
            <input
              matInput
              required
              #userInput
              [(ngModel)]="scdl.user_id"
              [matAutocomplete]="userAuto"
              (focus)="userSearch.set('')"
              (input)="userSearch.set(userInput.value)"
              #userCtrl="ngModel"
            />
            <mat-autocomplete
              #userAuto="matAutocomplete"
              requireSelection
              [displayWith]="displayUserName.bind(this)"
            >
              @for (opt of filteredUsers(); track opt.value) {
                <mat-option [value]="opt.value">{{ opt.label }}</mat-option>
              }
            </mat-autocomplete>
          </mat-form-field>

          <mat-form-field appearance="outline" subscriptSizing="dynamic">
            <mat-label>Work Date</mat-label>
            <input
              matInput
              [matDatepicker]="picker"
              [ngModel]="bindDate()"
              (ngModelChange)="bindDate.set($event)"
              required
            />
            <mat-datepicker-toggle
              matIconSuffix
              [for]="picker"
            ></mat-datepicker-toggle>
            <mat-datepicker #picker></mat-datepicker>
          </mat-form-field>
        </div>
      </section>

      <section
        class="form-group"
        style="
          background-color: var(--mat-sys-surface-variant);
          padding: 16px;
          border-radius: 12px;
        "
      >
        <div
          style="
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
          "
        >
          <h3 style="margin: 0; font-size: 16px; font-weight: 600">
            Shift Details
          </h3>
          <mat-slide-toggle [(ngModel)]="scdl.is_day_off" color="primary">
            Mark as Day Off
          </mat-slide-toggle>
        </div>

        @if (!scdl.is_day_off) {
          <button
            mat-stroked-button
            color="primary"
            type="button"
            (click)="applyFixedShiftShortcut()"
            style="width: 100%; margin-bottom: 16px; height: 40px; font-size: 14px;"
          >
            <mat-icon
              style="
                font-size: 18px;
                width: 18px;
                height: 18px;
                margin-right: 6px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
              "
            >flash_on</mat-icon>
            Apply 09:00 - 17:00 Shift
          </button>

          <mat-form-field
            appearance="outline"
            subscriptSizing="dynamic"
            class="full-width"
          >
            <mat-label>Select Employment</mat-label>
            <mat-select [(ngModel)]="scdl.mplm_id" required>
              @for (
                emp of filteredEmployments();
                track emp.tb_tyapp_wk_mplm_id
              ) {
                <mat-option [value]="emp.tb_tyapp_wk_mplm_id">
                  {{ emp.employer_name_en }} ({{ emp.position_title_en }})
                </mat-option>
              }
            </mat-select>
