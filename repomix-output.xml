            </mat-autocomplete>
            @if (catCtrl.invalid && (catCtrl.dirty || catCtrl.touched)) {
              <mat-error
                >Please select a valid category from the list.</mat-error
              >
            }
          </mat-form-field>

          <mat-form-field appearance="outline" subscriptSizing="dynamic">
            <mat-label>Log Author</mat-label>
            <input
              matInput
              required
              #userInput
              [(ngModel)]="log.log_user"
              [matAutocomplete]="userAuto"
              (focus)="userSearch.set('')"
              (input)="userSearch.set(userInput.value)"
              #userCtrl="ngModel"
            />
            <mat-autocomplete
              #userAuto="matAutocomplete"
              requireSelection
              [displayWith]="displayUserName.bind(this)"
            >
              @for (opt of filteredUsers(); track opt.value) {
                <mat-option [value]="opt.value">{{ opt.label }}</mat-option>
              }
            </mat-autocomplete>
            @if (userCtrl.invalid && (userCtrl.dirty || userCtrl.touched)) {
              <mat-error>Please select a valid author from the list.</mat-error>
            }
          </mat-form-field>
        </div>
