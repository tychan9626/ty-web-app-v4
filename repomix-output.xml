<div class="split-workspace">
  @if (item(); as log) {
    <div class="form-scroll-area">
      <section class="form-group">
        <h3 class="group-header">Version Info</h3>
        <div class="fields-grid-2">
          <div style="display: flex; flex-direction: column; gap: 8px">
            <div
              style="
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
                gap: 8px;
              "
            >
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Major</mat-label>
                <input
                  matInput
                  type="number"
                  [(ngModel)]="log.version_major"
                  required
                  min="0"
                />
              </mat-form-field>
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Minor</mat-label>
                <input
                  matInput
                  type="number"
                  [(ngModel)]="log.version_minor"
                  required
                  min="0"
                />
              </mat-form-field>
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Patch</mat-label>
                <input
                  matInput
                  type="number"
                  [(ngModel)]="log.version_patch"
                  required
                  min="0"
                />
              </mat-form-field>
            </div>

            @if (!currentId) {
              <div style="display: flex; gap: 8px; flex-wrap: wrap">
                <button
                  mat-button
                  type="button"
                  (click)="bumpMajor()"
                  style="flex: 1; min-width: 80px"
                >
                  + Major
                </button>
                <button
                  mat-button
                  type="button"
                  (click)="bumpMinor()"
                  style="flex: 1; min-width: 80px"
                >
                  + Minor
                </button>
                <button
                  mat-button
                  type="button"
                  (click)="bumpPatch()"
                  style="flex: 1; min-width: 80px"
                >
                  + Patch
                </button>
              </div>
            }
          </div>

          <div
            style="
              display: flex;
              flex-direction: column;
              justify-content: flex-start;
            "
          >
            <mat-form-field
              appearance="outline"
              subscriptSizing="dynamic"
              class="full-width"
            >
              <mat-label>Release Date</mat-label>
              <input
                matInput
                [matDatepicker]="picker"
                [(ngModel)]="log.version_date"
                required
              />
              <mat-datepicker-toggle
                matIconSuffix
                [for]="picker"
              ></mat-datepicker-toggle>
              <mat-datepicker #picker></mat-datepicker>
            </mat-form-field>
          </div>
        </div>
      </section>

      <section class="form-group">
        <h3 class="group-header">Context & Author</h3>
        <div class="fields-grid-2">
          <mat-form-field appearance="outline" subscriptSizing="dynamic">
            <mat-label>App Category</mat-label>
            <input
              matInput
              required
              #catInput
              [(ngModel)]="log.category_id"
              [matAutocomplete]="catAuto"
              (focus)="catSearch.set('')"
              (input)="catSearch.set(catInput.value)"
              #catCtrl="ngModel"
            />
            <mat-autocomplete
              #catAuto="matAutocomplete"
              requireSelection
              [displayWith]="displayCategoryName.bind(this)"
            >
              @for (opt of filteredCategories(); track opt.value) {
                <mat-option [value]="opt.value">{{ opt.label }}</mat-option>
