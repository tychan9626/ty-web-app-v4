              #userCtrl="ngModel"
            />
            <mat-autocomplete
              #userAuto="matAutocomplete"
              requireSelection
              [displayWith]="displayUserName.bind(this)"
            >
              @for (opt of filteredUsers(); track opt.value) {
                <mat-option [value]="opt.value">{{ opt.label }}</mat-option>
