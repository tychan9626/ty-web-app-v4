            <td class="center" [class.highlight-date]="!isExpired(txn.end_date) && txn.end_date">{{ txn.end_date || '--' }}</td>
            <td class="amount-cell interest">{{ txn.earned_interest ? (txn.earned_interest | number:'1.2') : '--' }}</td>
            <td class="amount-cell total-bold">
                @if (txn.transaction_type === 'fx_exchange') {
                    ➔ {{ txn.deposit_amount | number:'1.2' }}
                } @else if (txn.transaction_type === 'term_deposit') {
                    {{ txn.return_amount | number:'1.2' }}
                } @else {
                    {{ txn.deposit_amount | number:'1.2' }}
                }
            </td>
          </tr>
        } @empty {
          <tr>
            <td colspan="12" class="center muted">目前沒有活躍的交易項目</td>
          </tr>
        }
      </tbody>
    </table>

    <div class="report-footer">
      <p>香港時間：{{ hkTime }}</p>
<p>多倫多時間：{{ torontoTime }}</p>
    </div>
  </div>
</div>
