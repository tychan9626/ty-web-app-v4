            <td class="center">{{ txn.start_date }}</td>
            <td class="amount-cell">
                @if (txn.transaction_type === 'fx_exchange') {
                    {{ txn.fx_source_amount | number:'1.2' }}
                } @else {
                    {{ txn.deposit_amount | number:'1.2' }}
