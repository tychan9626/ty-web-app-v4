    <div class="sidebar-wrapper">
      <mat-toolbar class="sidebar-logo" routerLink="/welcome">
        <img src="logo.svg" alt="Jaxfr Logo" class="brand-logo">
      </mat-toolbar>

      <div class="sidebar-user-profile">
        <mat-icon class="avatar">account_circle</mat-icon>
        <div class="info">
          <span class="name">{{ userProfile() | tyDisplayName }}</span>
          <span class="role">{{ userProfile()?.role | tyRoleLabel }}</span>
        </div>
      </div>

      <nav class="nav-container">
        @for (group of navMenu(); track group.title) {
          <mat-accordion displayMode="flat">
            <mat-expansion-panel class="nav-panel" [expanded]="true">
              <mat-expansion-panel-header>
                <mat-panel-title>
                  <mat-icon>{{ group.icon }}</mat-icon>
                  <span>{{ group.title }}</span>
                </mat-panel-title>
              </mat-expansion-panel-header>

              <div class="sub-menu">
                @for (link of group.links; track link.route) {
                  <a
                    mat-list-item
                    [routerLink]="link.route"
                    routerLinkActive="active-sub-link"
                    (click)="closeOnMobile()"
                  >
                    <span matListItemTitle>{{ link.title }}</span>
                  </a>
                }
              </div>
            </mat-expansion-panel>
          </mat-accordion>
        }
      </nav>

      <span class="spacer"></span>

      <button mat-button class="sidebar-logout" (click)="onSignOut()">
        <mat-icon>logout</mat-icon>
        <span>Sign Out</span>
      </button>
      <div class="sidebar-footer">App Version: {{ appVersion() }}</div>
    </div>
  </mat-sidenav>

  <mat-sidenav-content class="content-wrapper">
    <mat-toolbar class="dynamic-navbar">
      <div class="nav-slot">
        @if (isHandset()) {
          <button mat-icon-button (click)="drawer.toggle()">
            <mat-icon>menu</mat-icon>
          </button>
        }
      </div>

      <div class="header-portal-slot">
        @if (headerService.config(); as config) {
          <div class="page-toolbar-wrapper">
            <div class="left-actions">
              @if (config.backLink) {
                <button mat-icon-button [routerLink]="config.backLink">
                  <mat-icon>west</mat-icon>
                </button>
              }
              @if (config.title) {
                <span class="page-title">{{ config.title }}</span>
              }
            </div>

            <div class="right-actions">
              @if (config.syncStatus && config.syncStatus() !== "none") {
                <div class="sync-status-indicator">
                  @switch (config.syncStatus()) {
                    @case ("loading") {
                      <mat-spinner diameter="16"></mat-spinner>
                      <span class="status-text desktop-only">Syncing...</span>
                    }
                    @case ("unsaved") {
                      <mat-icon
                        style="
                          color: var(--mat-sys-error);
                          font-size: 16px;
                          width: 16px;
                          height: 16px;
                        "
                        >error_outline</mat-icon
                      >
                      <span
                        class="status-text desktop-only"
                        style="color: var(--mat-sys-error)"
                        >Unsaved changes</span
                      >
                    }
                    @case ("up-to-date") {
                      <mat-icon class="success-icon">cloud_done</mat-icon>
                      <span class="status-text desktop-only">Up to date</span>
                    }
                  }
                </div>
              }

              @for (action of getToggleActions(config.actions); track action.label) {
                <mat-slide-toggle
                  color="primary"
                  style="margin-right: 12px; font-weight: 500;"
                  [checked]="action.checked"
                  (change)="action.onChange && action.onChange($event.checked)"
                  [disabled]="action.disabled ? action.disabled() : false"
                >
                  <span class="desktop-only">{{ action.label }}</span>
                  
                  @if (action.icon) {
                    <mat-icon class="mobile-only" style="vertical-align: middle; font-size: 20px; width: 20px; height: 20px;">
                      {{ action.icon }}
                    </mat-icon>
                  }
                </mat-slide-toggle>
              }

              @for (
                action of getSecondaryActions(config.actions);
                track action.label
              ) {
                <button
                  mat-button
                  class="desktop-only"
                  (click)="action.onClick ? action.onClick() : null"
                  [disabled]="action.disabled ? action.disabled() : false"
                >
                  <mat-icon>{{ action.icon }}</mat-icon>
                  <span>{{ action.label }}</span>
                </button>
              }

              @for (
                action of getPrimaryActions(config.actions);
                track action.label
              ) {
                <button
                  mat-flat-button
                  color="primary"
                  class="primary-action-btn"
                  (click)="action.onClick ? action.onClick() : null"
                  [disabled]="action.disabled ? action.disabled() : false"
                >
                  <mat-icon>{{ action.icon }}</mat-icon>
                  <span class="desktop-only">{{ action.label }}</span>
                </button>
              }

              @if (getSecondaryActions(config.actions).length > 0) {
                <div class="mobile-menu-trigger">
                  <button mat-icon-button [matMenuTriggerFor]="moreMenu">
                    <mat-icon>more_vert</mat-icon>
                  </button>
                  <mat-menu #moreMenu="matMenu">
                    @for (
                      action of getSecondaryActions(config.actions);
                      track action.label
                    ) {
                      <button
                        mat-menu-item
                        (click)="action.onClick ? action.onClick() : null"
                        [disabled]="action.disabled ? action.disabled() : false"
                      >
                        <mat-icon>{{ action.icon }}</mat-icon>
                        <span>{{ action.label }}</span>
                      </button>
                    }
                  </mat-menu>
                </div>
              }
            </div>
          </div>
        }
      </div>
    </mat-toolbar>

    <main class="main-scroll-view">
      <div class="page-container">
        <router-outlet></router-outlet>
      </div>
    </main>
  </mat-sidenav-content>
</mat-sidenav-container>
</file>

