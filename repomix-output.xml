      1: 'Legal Name (First Middle Last)',
      2: 'Legal Name (Last Middle First)',
      3: 'Preferred Name (First Middle Last)',
      4: 'Preferred Name (Last Middle First)',
      5: 'Customized Only'
    };
    return modes[mode] || `Unknown Mode (${mode})`;
  }
