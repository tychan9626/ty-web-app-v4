                />
              </mat-form-field>
              <button
                mat-button
                color="accent"
                type="button"
                class="shortcut-btn"
                (click)="
                  updateTimeInput(
                    'break_end',
                    addMins(timeInputs().break_start, 30)
                  )
                "
                style="background: rgba(var(--mat-sys-accent-rgb), 0.1)"
              >
                + 30 mins
              </button>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px">
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>End Time (Clock Out)</mat-label>
                <input matInput type="time" [(ngModel)]="timeInputs().end" />
              </mat-form-field>
              <button
                mat-button
                color="primary"
                type="button"
                class="shortcut-btn"
                (click)="updateTimeInput('end', '17:00')"
                style="background: rgba(var(--mat-sys-primary-rgb), 0.08)"
              >
                17:00
              </button>
            </div>
          </div>
        } @else {
          <div
            style="
              color: var(--mat-sys-outline);
              font-size: 14px;
              padding: 8px 0;
            "
          >
            This day is marked as a day off. No clock-in data needed.
          </div>
        }
      </section>

      <section class="form-group">
        <h3 class="group-header">Logs & Status</h3>

        <mat-form-field
          appearance="outline"
          class="full-width"
          subscriptSizing="dynamic"
          style="margin-bottom: 8px"
        >
          <mat-label>Log / Remarks</mat-label>
          <textarea matInput rows="10" [(ngModel)]="attn.log"></textarea>
        </mat-form-field>

        <mat-slide-toggle
          [(ngModel)]="attn.log_is_secret"
