                <button
                  mat-button
                  color="primary"
                  type="button"
                  class="shortcut-btn"
                  (click)="updateTimeInput('meal_start', '12:45')"
                  style="background: rgba(var(--mat-sys-primary-rgb), 0.08)"
                >
                  12:45
                </button>
                <button
                  mat-button
                  color="primary"
                  type="button"
                  class="shortcut-btn"
                  (click)="updateTimeInput('meal_start', '13:15')"
                  style="background: rgba(var(--mat-sys-primary-rgb), 0.08)"
                >
                  13:15
                </button>
                <button
                  mat-button
                  color="primary"
                  type="button"
                  class="shortcut-btn"
                  (click)="updateTimeInput('meal_start', '13:45')"
                  style="background: rgba(var(--mat-sys-primary-rgb), 0.08)"
                >
                  13:45
                </button>
              </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px">
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Meal End</mat-label>
                <input
                  matInput
                  type="time"
