            <div style="display: flex; flex-direction: column; gap: 6px">
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Break Start</mat-label>
                <input
                  matInput
                  type="time"
                  [(ngModel)]="timeInputs().break_start"
                />
              </mat-form-field>
              <button
                mat-button
                color="primary"
                type="button"
                class="shortcut-btn"
                (click)="updateTimeInput('break_start', timeInputs().meal_end)"
                style="background: rgba(var(--mat-sys-primary-rgb), 0.08)"
              >
                = Meal End
              </button>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px">
              <mat-form-field appearance="outline" subscriptSizing="dynamic">
                <mat-label>Break End</mat-label>
                <input
