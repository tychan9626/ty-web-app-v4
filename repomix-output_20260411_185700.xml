            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
          "
        >
          <h3 style="margin: 0; font-size: 16px; font-weight: 600">
            Shift Details
          </h3>
          <mat-slide-toggle [(ngModel)]="scdl.is_day_off" color="primary">
            Mark as Day Off
